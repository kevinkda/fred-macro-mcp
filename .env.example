# ---------------------------------------------------------------------------
# fred-macro-mcp environment template.
#
# FRED (Federal Reserve Economic Data, St. Louis Fed) requires a free API key.
# Register at: https://fred.stlouisfed.org/docs/api/api_key.html
#
# Copy this file to .env (which is gitignored) and edit the values below.
# The key is a 32-character lowercase alphanumeric string. It is read from
# the environment only, never logged or echoed (errors.py redacts it).
# ---------------------------------------------------------------------------

# REQUIRED — your FRED API key (32-char lowercase alphanumeric).
# Get one (free) at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=  # pragma: allowlist secret

# OPTIONAL — override the client-side rate limit (requests per minute).
# FRED allows 120 req/min; a token bucket in src/fred_macro_mcp/client.py
# defaults to 120 to stay within the documented ceiling.
FRED_RATE_LIMIT_PER_MIN=120

# OPTIONAL — cache toggles (default: DISABLED / opt-in).
# The read-through cache is OFF by default — every tool hits FRED live
# (reporting _cache_status="disabled"). Enable explicitly (also accepts
# true/yes/on):
# FRED_CACHE_ENABLED=true
# Bypass reads while still writing (rarely needed):
# FRED_CACHE_BYPASS=0

# OPTIONAL — cache backend selection (default: memory).
#   memory     — in-process LRU + TTL, zero external dependency (default).
#   clickhouse — durable derived-analysis history; requires the extra
#                `pip install fred-macro-mcp[clickhouse]` AND a URL below.
# FRED_CACHE_BACKEND=memory
# ClickHouse DSN (only used when FRED_CACHE_BACKEND=clickhouse):
# FRED_CLICKHOUSE_URL=clickhouse://user:pass@host:8123/db  # pragma: allowlist secret

# OPTIONAL — log level (default: WARNING).
LOG_LEVEL=WARNING
